# =============================================================================
# .env.example — Privello
# -----------------------------------------------------------------------------
# Copie este arquivo para `.env` e preencha os valores. Nenhum valor real
# é versionado aqui; tudo é placeholder/exemplo. Mantenha o `.env` fora do git
# (já coberto pelo .gitignore: `.env*` exceto `.env` e este `.env.example`).
# =============================================================================


# -----------------------------------------------------------------------------
# Auth (NextAuth v5)
# -----------------------------------------------------------------------------

# Segredo de assinatura do JWT/CSRF. Gere com: `openssl rand -base64 32`.
# Obrigatório em qualquer ambiente.
AUTH_SECRET=

# URL pública do app em produção (ex.: `https://privello.com.br`, sem barra final).
# Obrigatório em produção: o build/start falha em prod sem ela
# (ver `src/lib/auth.ts:9-16`). Em dev pode ficar vazio — NextAuth aceita
# `Host` arbitrário quando `trustHost: true` está ativo no ambiente de dev.
# Doc de referência: `.kiro/specs/fase-1-seguranca/nextauth-prod.md`.
AUTH_URL=

# URL base usada nos links de email (confirmação, recuperação, etc.).
# Em dev costuma ser `http://localhost:3000`.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Origens adicionais aceitas em dev (ngrok, IP da rede local), separadas
# por vírgula. Vazio em produção.
NEXT_DEV_ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Dev endpoints (`/api/dev/**`)
# -----------------------------------------------------------------------------

# Token estático para acessar `/api/dev/*` sem sessão NextAuth. Uso apenas
# em dev/staging; em produção, autentique via sessão admin (ADMIN/MODERATOR).
# Comparado em tempo constante via `crypto.timingSafeEqual` em
# `src/lib/security/dev-auth.ts`.
# Geração recomendada: `openssl rand -hex 32`.
# Ref.: `.kiro/specs/fase-1-seguranca/tasks.md` > 1.4.
DEV_ENDPOINT_TOKEN=


# -----------------------------------------------------------------------------
# Cron endpoints (`/api/cron/**`)
# -----------------------------------------------------------------------------

# Segredo dos cron endpoints. Forma preferida:
#   Authorization: Bearer $CRON_SECRET
# ou:
#   X-Cron-Secret: $CRON_SECRET
# A query string `?secret=$CRON_SECRET` é aceita até 2026-06-15T00:00:00Z
# (janela de transição) e emite warning estruturado; após essa data o uso
# por query passa a ser rejeitado. Ver `src/lib/security/cron-auth.ts`.
# Geração recomendada: `openssl rand -hex 32`.
CRON_SECRET=


# -----------------------------------------------------------------------------
# Imagens (next/image — `next.config.ts > images.remotePatterns`)
# -----------------------------------------------------------------------------

# Hostname público do app em produção (ex.: `privello.com.br`, sem protocolo
# nem barra final). Lido por `next.config.ts > images.remotePatterns` (task
# 3.2 da fase-1-seguranca) para liberar imagens servidas pelo próprio domínio.
# Vazio em dev — o whitelist em dev usa `picsum.photos` e os hosts auxiliares
# declarados em `next.config.ts`.
PRODUCTION_HOSTNAME=


# -----------------------------------------------------------------------------
# Database (Prisma / PostgreSQL)
# -----------------------------------------------------------------------------

# Connection string do Postgres. Em dev local é típico apontar para o
# `docker-compose.yml` deste repo. Não versionar credenciais reais.
DATABASE_URL=postgresql://user:password@localhost:5432/privello?schema=public


# -----------------------------------------------------------------------------
# Email (SMTP — Gmail com App Password ou outro provedor)
# -----------------------------------------------------------------------------

# Para ativar com Gmail: gere uma "Senha de app" em
# https://myaccount.google.com/apppasswords e use-a em EMAIL_PASS.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=


# -----------------------------------------------------------------------------
# Mercado Pago (pagamentos)
# -----------------------------------------------------------------------------

# Crie uma aplicação em https://www.mercadopago.com.br/developers e copie
# as credenciais. NÃO use o access token de produção em ambiente de dev.

# Credencial privada (servidor) — ex.: `APP_USR-...`
MERCADOPAGO_ACCESS_TOKEN=

# Credencial pública (cliente) — ex.: `APP_USR-...` — ativa o checkout
NEXT_PUBLIC_MP_PUBLIC_KEY=

# Segredo HMAC do webhook do Mercado Pago. Em dev pode ficar vazio (o handler
# loga warn e aceita o request sem assinatura). Em produção, defina com
# `openssl rand -hex 32` para que o webhook rejeite requests sem assinatura
# válida. Ver `src/app/api/mp/webhook/route.ts`.
MP_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Observabilidade / Debug (opt-in)
# -----------------------------------------------------------------------------

# Ativa instrumentação opt-in de queries do Prisma (eventos `query`/`error`/`warn`).
# Overhead zero quando desligado. Use `1` para ativar; deixe vazio para desligar.
# Ver `src/lib/prisma.ts` e `.kiro/specs/fase-3-backend/metricas-baseline.md > §2.1`.
PRISMA_DEBUG_QUERIES=
