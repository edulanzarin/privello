# -----------------------------------------------------------------------------
# Auth (NextAuth v5)
# -----------------------------------------------------------------------------

# Segredo de assinatura do JWT/CSRF. Gere com: `openssl rand -base64 32`.
# ObrigatĂłrio em qualquer ambiente.
AUTH_SECRET=

# URL pĂșblica do app em produĂ§ĂŁo (ex.: `https://privello.com.br`, sem barra final).
# ObrigatĂłrio em produĂ§ĂŁo: o build/start falha em prod sem ela
# (ver `src/lib/auth.ts:9-16`). Em dev pode ficar vazio â NextAuth aceita
# `Host` arbitrĂĄrio quando `trustHost: true` estĂĄ ativo no ambiente de dev.
# Doc de referĂȘncia: `.kiro/specs/fase-1-seguranca/nextauth-prod.md`.
AUTH_URL=

# URL base usada nos links de email (confirmaĂ§ĂŁo, recuperaĂ§ĂŁo, etc.).
# Em dev costuma ser `http://localhost:3000`.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Origens adicionais aceitas em dev (ngrok, IP da rede local), separadas
# por vĂ­rgula. Vazio em produĂ§ĂŁo.
NEXT_DEV_ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Dev endpoints (`/api/dev/**`)
# -----------------------------------------------------------------------------

# Token estĂĄtico para acessar `/api/dev/*` sem sessĂŁo NextAuth. Uso apenas
# em dev/staging; em produĂ§ĂŁo, autentique via sessĂŁo admin (ADMIN/MODERATOR).
# Comparado em tempo constante via `crypto.timingSafeEqual` em
# `src/lib/security/dev-auth.ts`.
# GeraĂ§ĂŁo recomendada: `openssl rand -hex 32`.
# Ref.: `.kiro/specs/fase-1-seguranca/tasks.md` > 1.4.
DEV_ENDPOINT_TOKEN=


# -----------------------------------------------------------------------------
# Cron endpoints (`/api/cron/**`)
# -----------------------------------------------------------------------------

# Segredo dos cron endpoints. Forma preferida:
#   Authorization: Bearer $CRON_SECRET
# ou:
#   X-Cron-Secret: $CRON_SECRET
# A query string `?secret=$CRON_SECRET` Ă© aceita atĂ© 2026-06-15T00:00:00Z
# (janela de transiĂ§ĂŁo) e emite warning estruturado; apĂłs essa data o uso
# por query passa a ser rejeitado. Ver `src/lib/security/cron-auth.ts`.
# GeraĂ§ĂŁo recomendada: `openssl rand -hex 32`.
CRON_SECRET=


# -----------------------------------------------------------------------------
# Imagens (next/image â `next.config.ts > images.remotePatterns`)
# -----------------------------------------------------------------------------

# Hostname pĂșblico do app em produĂ§ĂŁo (ex.: `privello.com.br`, sem protocolo
# nem barra final). Lido por `next.config.ts > images.remotePatterns` (task
# 3.2 da fase-1-seguranca) para liberar imagens servidas pelo prĂłprio domĂ­nio.
# Vazio em dev â o whitelist em dev usa `picsum.photos` e os hosts auxiliares
# declarados em `next.config.ts`.
PRODUCTION_HOSTNAME=


# -----------------------------------------------------------------------------
# Database (Prisma / PostgreSQL)
# -----------------------------------------------------------------------------

# Connection string do Postgres. Em dev local Ă© tĂ­pico apontar para o
# `docker-compose.yml` deste repo. NĂŁo versionar credenciais reais.
DATABASE_URL=postgresql://user:password@localhost:5432/privello?schema=public


# -----------------------------------------------------------------------------
# Email (SMTP â Gmail com App Password ou outro provedor)
# -----------------------------------------------------------------------------

# Para ativar com Gmail: gere uma "Senha de app" em
# https://myaccount.google.com/apppasswords e use-a em EMAIL_PASS.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=


# -----------------------------------------------------------------------------
# Mercado Pago (pagamentos)
# -----------------------------------------------------------------------------

# Crie uma aplicaĂ§ĂŁo em https://www.mercadopago.com.br/developers e copie
# as credenciais. NĂO use o access token de produĂ§ĂŁo em ambiente de dev.

# Credencial privada (servidor) â ex.: `APP_USR-...`
MERCADOPAGO_ACCESS_TOKEN=

# Credencial pĂșblica (cliente) â ex.: `APP_USR-...` â ativa o checkout
NEXT_PUBLIC_MP_PUBLIC_KEY=
