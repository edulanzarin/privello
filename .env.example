# -----------------------------------------------------------------------------
# Auth (NextAuth v5)
# -----------------------------------------------------------------------------

# Segredo de assinatura do JWT/CSRF. Gere com: `openssl rand -base64 32`.
# ObrigatĂ³rio em qualquer ambiente.
AUTH_SECRET=

# URL pĂºblica do app em produĂ§Ă£o (ex.: `https://privello.com.br`, sem barra final).
# ObrigatĂ³rio em produĂ§Ă£o: o build/start falha em prod sem ela
# (ver `src/lib/auth.ts:9-16`). Em dev pode ficar vazio â€” NextAuth aceita
# `Host` arbitrĂ¡rio quando `trustHost: true` estĂ¡ ativo no ambiente de dev.
# Doc de referĂªncia: `.kiro/specs/fase-1-seguranca/nextauth-prod.md`.
AUTH_URL=

# URL base usada nos links de email (confirmaĂ§Ă£o, recuperaĂ§Ă£o, etc.).
# Em dev costuma ser `http://localhost:3000`.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Origens adicionais aceitas em dev (ngrok, IP da rede local), separadas
# por vĂ­rgula. Vazio em produĂ§Ă£o.
NEXT_DEV_ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Dev endpoints (`/api/dev/**`)
# -----------------------------------------------------------------------------

# Token estĂ¡tico para acessar `/api/dev/*` sem sessĂ£o NextAuth. Uso apenas
# em dev/staging; em produĂ§Ă£o, autentique via sessĂ£o admin (ADMIN/MODERATOR).
# Comparado em tempo constante via `crypto.timingSafeEqual` em
# `src/lib/security/dev-auth.ts`.
# GeraĂ§Ă£o recomendada: `openssl rand -hex 32`.
# Ref.: `.kiro/specs/fase-1-seguranca/tasks.md` > 1.4.
DEV_ENDPOINT_TOKEN=


# -----------------------------------------------------------------------------
# Cron endpoints (`/api/cron/**`)
# -----------------------------------------------------------------------------

# Segredo dos cron endpoints. Forma preferida:
#   Authorization: Bearer $CRON_SECRET
# ou:
#   X-Cron-Secret: $CRON_SECRET
# A query string `?secret=$CRON_SECRET` Ă© aceita atĂ© 2026-06-15T00:00:00Z
# (janela de transiĂ§Ă£o) e emite warning estruturado; apĂ³s essa data o uso
# por query passa a ser rejeitado. Ver `src/lib/security/cron-auth.ts`.
# GeraĂ§Ă£o recomendada: `openssl rand -hex 32`.
CRON_SECRET=


# -----------------------------------------------------------------------------
# Imagens (next/image â€” `next.config.ts > images.remotePatterns`)
# -----------------------------------------------------------------------------

# Hostname pĂºblico do app em produĂ§Ă£o (ex.: `privello.com.br`, sem protocolo
# nem barra final). Lido por `next.config.ts > images.remotePatterns` (task
# 3.2 da fase-1-seguranca) para liberar imagens servidas pelo prĂ³prio domĂ­nio.
# Vazio em dev â€” o whitelist em dev usa `picsum.photos` e os hosts auxiliares
# declarados em `next.config.ts`.
PRODUCTION_HOSTNAME=


# -----------------------------------------------------------------------------
# Database (Prisma / PostgreSQL)
# -----------------------------------------------------------------------------

# Connection string do Postgres. Em dev local Ă© tĂ­pico apontar para o
# `docker-compose.yml` deste repo. NĂ£o versionar credenciais reais.
DATABASE_URL=postgresql://user:password@localhost:5432/privello?schema=public


# -----------------------------------------------------------------------------
# Email (SMTP â€” Gmail com App Password ou outro provedor)
# -----------------------------------------------------------------------------

# Para ativar com Gmail: gere uma "Senha de app" em
# https://myaccount.google.com/apppasswords e use-a em EMAIL_PASS.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=


# -----------------------------------------------------------------------------
# Mercado Pago (pagamentos)
# -----------------------------------------------------------------------------

# Crie uma aplicaĂ§Ă£o em https://www.mercadopago.com.br/developers e copie
# as credenciais. NĂƒO use o access token de produĂ§Ă£o em ambiente de dev.

# Credencial privada (servidor) â€” ex.: `APP_USR-...`
MERCADOPAGO_ACCESS_TOKEN=

# Credencial pĂºblica (cliente) â€” ex.: `APP_USR-...` â€” ativa o checkout
NEXT_PUBLIC_MP_PUBLIC_KEY=

# Segredo HMAC do webhook do Mercado Pago. Em dev pode ficar vazio (o handler
# loga warn e aceita o request sem assinatura). Em produĂ§Ă£o, defina com
# `openssl rand -hex 32` para que o webhook rejeite requests sem assinatura
# vĂ¡lida. Ver `src/app/api/mp/webhook/route.ts`.
MP_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Observabilidade / Debug (opt-in)
# -----------------------------------------------------------------------------

# Ativa instrumentaĂ§Ă£o opt-in de queries do Prisma (eventos `query`/`error`/`warn`).
# Overhead zero quando desligado. Use `1` para ativar; deixe vazio para desligar.
# Ver `src/lib/prisma.ts` e `.kiro/specs/fase-3-backend/metricas-baseline.md > Â§2.1`.
PRISMA_DEBUG_QUERIES=


# -----------------------------------------------------------------------------
# Storage (Cloudflare R2 â€” produĂ§Ă£o)
# -----------------------------------------------------------------------------

# Bucket S3-compatible no Cloudflare R2 que recebe os arquivos enviados pelos
# usuĂ¡rios (mĂ­dias do diretĂ³rio, Ă¡udios, documentos de verificaĂ§Ă£o, avatares).
# Consumido por `src/lib/storage.ts` (Storage_Module) e por
# `next.config.ts > images.remotePatterns`.
#
# Em DEV todas as 5 variĂ¡veis abaixo sĂ£o OPCIONAIS: quando `R2_ACCESS_KEY_ID`,
# `R2_SECRET_ACCESS_KEY` e `R2_BUCKET_NAME` estĂ£o completamente ausentes e
# `NODE_ENV !== "production"`, o Storage_Module ativa o Storage_Local_Fallback
# (escreve em `public/<key>` e devolve URL relativa).
#
# Em PRODUĂ‡ĂƒO o trio mĂ­nimo (`R2_ACCESS_KEY_ID`, `R2_SECRET_ACCESS_KEY`,
# `R2_BUCKET_NAME`) Ă© OBRIGATĂ“RIO â€” o Storage_Module lanĂ§a erro descritivo no
# primeiro `putObject`/`deleteObject` se algum deles estiver vazio.
# Ver `.kiro/specs/migracao-infra-producao/design.md > Â§"Storage_Module"`.

# Account ID do Cloudflare (visĂ­vel no dashboard da conta R2). CompĂµe o endpoint
# canĂ´nico `https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com`.
R2_ACCOUNT_ID=

# Access Key ID emitido em "R2 â†’ Manage R2 API Tokens". Credencial pĂºblica do
# par S3 v4 â€” obrigatĂ³rio em produĂ§Ă£o.
R2_ACCESS_KEY_ID=

# Secret Access Key emitido junto com o Access Key ID. NUNCA versionar o valor
# real. ObrigatĂ³rio em produĂ§Ă£o.
R2_SECRET_ACCESS_KEY=

# Nome do bucket R2 que receberĂ¡ os uploads (ex.: `privello-prod`). Os objetos
# sĂ£o organizados por prefixo: `uploads/<id>/...`, `audio/<id>/...`,
# `verification/<id>/...`. ObrigatĂ³rio em produĂ§Ă£o.
R2_BUCKET_NAME=

# URL pĂºblica base do bucket (ex.: `https://pub-<id>.r2.dev` em fase inicial,
# ou `https://cdn.privello.com.br` quando atrĂ¡s do Cloudflare CDN). Sem barra
# final â€” o Storage_Module faz trim. Usada para compor a URL persistida em
# `Media.url`, `Profile.audioUrl`, `User.image` e `VerificationCase.*`.
R2_PUBLIC_URL=
